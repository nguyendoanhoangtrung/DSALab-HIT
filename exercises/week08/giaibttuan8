Bài 1: Cài đặt Stack ⭐⭐
Cài đặt Stack bằng mảng (array-based) và bằng Linked List. So sánh ưu nhược điểm.
#include <iostream>

using namespace std;

struct ArrayStack {
    int* data;
    int topIndex;
    int capacity;
};

void initArray(ArrayStack &s, int cap) {
    s.capacity = cap;
    s.topIndex = -1;
    s.data = new int[cap];
}

bool isEmptyArray(ArrayStack s) {
    return s.topIndex == -1;
}

bool isFullArray(ArrayStack s) {
    return s.topIndex == s.capacity - 1;
}

void pushArray(ArrayStack &s, int val) {
    if (isFullArray(s)) return;
    s.topIndex++;
    s.data[s.topIndex] = val;
}

void popArray(ArrayStack &s) {
    if (isEmptyArray(s)) return;
    s.topIndex--;
}

int topArray(ArrayStack s) {
    if (isEmptyArray(s)) return -1;
    return s.data[s.topIndex];
}

void freeArray(ArrayStack &s) {
    delete[] s.data;
}

struct Node {
    int data;
    Node* next;
};

struct ListStack {
    Node* topNode;
};

void initList(ListStack &s) {
    s.topNode = nullptr;
}

bool isEmptyList(ListStack s) {
    return s.topNode == nullptr;
}

void pushList(ListStack &s, int val) {
    Node* newNode = new Node{val, s.topNode};
    s.topNode = newNode;
}

void popList(ListStack &s) {
    if (isEmptyList(s)) return;
    Node* temp = s.topNode;
    s.topNode = s.topNode->next;
    delete temp;
}

int topList(ListStack s) {
    if (isEmptyList(s)) return -1;
    return s.topNode->data;
}

void freeList(ListStack &s) {
    while (!isEmptyList(s)) {
        popList(s);
    }
}

int main() {
    ArrayStack s1;
    initArray(s1, 5);
    pushArray(s1, 10);
    pushArray(s1, 20);
    cout << "ArrayStack Top: " << topArray(s1) << endl;
    popArray(s1);
    cout << "ArrayStack Top sau khi Pop: " << topArray(s1) << endl;
    freeArray(s1);

    ListStack s2;
    initList(s2);
    pushList(s2, 100);
    pushList(s2, 200);
    cout << "ListStack Top: " << topList(s2) << endl;
    popList(s2);
    cout << "ListStack Top sau khi Pop: " << topList(s2) << endl;
    freeList(s2);

    cout << "\n=== SO SANH UU NHUOC DIEM ===\n";
    cout << "1. Stack dung Mang: Truy cap nhanh O(1), ton it bo nho cho con tro, nhung kich thuoc co dinh de bi loi Full Stack.\n";
    cout << "2. Stack dung DSLK: Linh hoat, khong lo bi day dung luong, nhung ton them bo nho de luu bien con tro 'next' va cap phat dong cham hon.\n";

    return 0;
}
Bài 2: Kiểm tra ngoặc hợp lệ ⭐⭐
Kiểm tra chuỗi có đóng mở ngoặc (), [], {} hợp lệ không. Xử lý cả chuỗi code thực tế.
#include <iostream>
#include <string>

using namespace std;

struct Node {
    char data;
    Node* next;
};

void push(Node* &top, char c) {
    Node* newNode = new Node{c, top};
    top = newNode;
}

void pop(Node* &top) {
    if (top == nullptr) return;
    Node* temp = top;
    top = top->next;
    delete temp;
}

char getTop(Node* top) {
    if (top == nullptr) return '\0';
    return top->data;
}

bool isEmpty(Node* top) {
    return top == nullptr;
}

bool kiemTraHopLe(string bieuThuc) {
    Node* stack = nullptr;
    for (int i = 0; i < bieuThuc.length(); i++) {
        char c = bieuThuc[i];
        if (c == '(' || c == '[' || c == '{') {
            push(stack, c);
        } else if (c == ')' || c == ']' || c == '}') {
            if (isEmpty(stack)) return false;
            char mo = getTop(stack);
            if ((c == ')' && mo == '(') || 
                (c == ']' && mo == '[') || 
                (c == '}' && mo == '{')) {
                pop(stack);
            } else {
                while (!isEmpty(stack)) pop(stack);
                return false;
            }
        }
    }
    bool ketQua = isEmpty(stack);
    while (!isEmpty(stack)) pop(stack);
    return ketQua;
}

int main() {
    string code1 = "if (arr[i] == {x}) { return (x + 1); }";
    string code2 = "if (arr[i] == {x) { return (x + 1); }";

    cout << "Chuoi 1: " << code1 << " -> " << (kiemTraHopLe(code1) ? "HOP LE" : "KHONG HOP LE") << endl;
    cout << "Chuoi 2: " << code2 << " -> " << (kiemTraHopLe(code2) ? "HOP LE" : "KHONG HOP LE") << endl;

    return 0;
}
Bài 3: Chuyển đổi biểu thức ⭐⭐⭐
Chuyển biểu thức Infix → Postfix → Prefix. In từng bước.
#include <iostream>
#include <string>

using namespace std;

struct Node {
    char data;
    Node* next;
};

void push(Node* &top, char c) {
    Node* newNode = new Node{c, top};
    top = newNode;
}

char pop(Node* &top) {
    if (top == nullptr) return '\0';
    Node* temp = top;
    char res = temp->data;
    top = top->next;
    delete temp;
    return res;
}

char peek(Node* top) {
    if (top == nullptr) return '\0';
    return top->data;
}

bool isEmpty(Node* top) {
    return top == nullptr;
}

int uuTien(char c) {
    if (c == '^') return 3;
    if (c == '*' || c == '/') return 2;
    if (c == '+' || c == '-') return 1;
    return 0;
}

void inStack(Node* top) {
    cout << "Stack: [";
    Node* temp = top;
    string s = "";
    while (temp != nullptr) {
        s = temp->data + s;
        temp = temp->next;
    }
    for (int i = 0; i < s.length(); i++) {
        cout << s[i] << (i == s.length() - 1 ? "" : ", ");
    }
    cout << "]";
}

string infixToPostfix(string infix) {
    Node* stack = nullptr;
    string postfix = "";
    int buoc = 1;

    cout << "\n--- QUA TRINH CHUYEN DOI ---\n";
    for (int i = 0; i < infix.length(); i++) {
        char c = infix[i];
        if (c == ' ') continue;

        if (isalnum(c)) {
            postfix += c;
        } else if (c == '(') {
            push(stack, c);
        } else if (c == ')') {
            while (!isEmpty(stack) && peek(stack) != '(') {
                postfix += pop(stack);
            }
            pop(stack);
        } else {
            while (!isEmpty(stack) && uuTien(peek(stack)) >= uuTien(c)) {
                postfix += pop(stack);
            }
            push(stack, c);
        }

        cout << "Buoc " << buoc++ << " | Ky tu: " << c << " | ";
        inStack(stack);
        cout << " | Postfix: " << postfix << endl;
    }

    while (!isEmpty(stack)) {
        postfix += pop(stack);
        cout << "Buoc " << buoc++ << " | Lay het tu Stack | ";
        inStack(stack);
        cout << " | Postfix: " << postfix << endl;
    }

    return postfix;
}

int main() {
    string infix = "(A+B)*C-D/E";
    cout << "Bieu thuc Infix: " << infix << endl;
    string postfix = infixToPostfix(infix);
    cout << "\n=> Ket qua Postfix: " << postfix << endl;
    return 0;
}
