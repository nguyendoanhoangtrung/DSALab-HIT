#include <iostream>
#include <string>
#include <cmath>

using namespace std;

struct CharNode {
    char data;
    CharNode* next;
};

void pushChar(CharNode* &top, char c) {
    top = new CharNode{c, top};
}

char popChar(CharNode* &top) {
    if (top == nullptr) return '\0';
    CharNode* t = top;
    char res = t->data;
    top = top->next;
    delete t;
    return res;
}

int uuTien(char c) {
    if (c == '^') return 3;
    if (c == '*' || c == '/') return 2;
    if (c == '+' || c == '-') return 1;
    return 0;
}

string bieuThucToPostfix(string infix) {
    CharNode* stack = nullptr;
    string postfix = "";
    for (int i = 0; i < infix.length(); i++) {
        char c = infix[i];
        if (c == ' ') continue;

        if (isdigit(c) || c == '.') {
            while (i < infix.length() && (isdigit(infix[i]) || infix[i] == '.')) {
                postfix += infix[i];
                i++;
            }
            postfix += ' ';
            i--;
        } else if (c == '(') {
            pushChar(stack, c);
        } else if (c == ')') {
            while (stack != nullptr && stack->data != '(') {
                postfix += popChar(stack);
                postfix += ' ';
            }
            popChar(stack);
        } else {
            while (stack != nullptr && uuTien(stack->data) >= uuTien(c)) {
                postfix += popChar(stack);
                postfix += ' ';
            }
            pushChar(stack, c);
        }
    }
    while (stack != nullptr) {
        postfix += popChar(stack);
        postfix += ' ';
    }
    return postfix;
}

struct DoubleNode {
    double data;
    DoubleNode* next;
};

void pushDouble(DoubleNode* &top, double v) {
    top = new DoubleNode{v, top};
}

double popDouble(DoubleNode* &top) {
    if (top == nullptr) return 0;
    DoubleNode* t = top;
    double res = t->data;
    top = top->next;
    delete t;
    return res;
}

void inStackDouble(DoubleNode* top) {
    cout << "Stack: [";
    DoubleNode* temp = top;
    string s = "";
    while (temp != nullptr) {
        s = to_string(temp->data) + (s == "" ? "" : ", ") + s;
        temp = temp->next;
    }
    cout << s << "]";
}

double tinhToanPostfix(string postfix) {
    DoubleNode* stack = nullptr;
    cout << "\nBuoc 2 --- Tinh toan:\n";

    for (int i = 0; i < postfix.length(); i++) {
        char c = postfix[i];
        if (c == ' ') continue;

        if (isdigit(c) || c == '.') {
            string numStr = "";
            while (i < postfix.length() && (isdigit(postfix[i]) || postfix[i] == '.')) {
                numStr += postfix[i];
                i++;
            }
            double val = stod(numStr);
            pushDouble(stack, val);
            cout << "  Push " << val << " -> ";
            inStackDouble(stack);
            cout << endl;
            i--;
        } else {
            double v2 = popDouble(stack);
            double v1 = popDouble(stack);
            double res = 0;

            if (c == '+') res = v1 + v2;
            else if (c == '-') res = v1 - v2;
            else if (c == '*') res = v1 * v2;
            else if (c == '/') res = v1 / v2;
            else if (c == '^') res = pow(v1, v2);

            pushDouble(stack, res);
            cout << "  '" << c << "' -> Pop " << v2 << ", Pop " << v1 << " -> Push " << res << " -> ";
            inStackDouble(stack);
            cout << endl;
        }
    }
    double ketQuaCuoi = popDouble(stack);
    return ketQuaCuoi;
}

int main() {
    string infix;
    cout << "=== MAY TINH BIEU THUC ===\n";
    cout << "Nhap bieu thuc: ";
    getline(cin, infix);

    string postfix = bieuThucToPostfix(infix);
    cout << "\nBuoc 1 --- Chuyen sang Postfix: " << postfix << endl;

    double kq = tinhToanPostfix(postfix);
    cout << "\n=> Ket qua: " << infix << " = " << kq << endl;

    return 0;
}
