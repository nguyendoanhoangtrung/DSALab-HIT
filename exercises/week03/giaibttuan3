#include <iostream>
#include <chrono>
#include <iomanip>

using namespace std;
using namespace std::chrono;

int linearSearch(int arr[], int n, int x) {
    for (int i = 0; i < n; i++) {
        if (arr[i] == x) return i;
    }
    return -1;
}

int binarySearch(int arr[], int n, int x) {
    int left = 0, right = n - 1;
    while (left <= right) {
        int mid = left + (right - left) / 2;
        if (arr[mid] == x) return mid;
        if (arr[mid] < x) left = mid + 1;
        else right = mid - 1;
    }
    return -1;
}

void chayThuNghiem(int n, double &tLinear, double &tBinary) {
    int* arr = new int[n];
    for (int i = 0; i < n; i++) {
        arr[i] = i;
    }
    int x = n - 1;

    auto start = high_resolution_clock::now();
    linearSearch(arr, n, x);
    auto end = high_resolution_clock::now();
    tLinear = duration<double, milli>(end - start).count();

    start = high_resolution_clock::now();
    binarySearch(arr, n, x);
    end = high_resolution_clock::now();
    tBinary = duration<double, milli>(end - start).count();

    delete[] arr;
}

int main() {
    double tL1 = 0, tB1 = 0;
    double tL2 = 0, tB2 = 0;
    double tL3 = 0, tB3 = 0;

    cout << "Dang chay thu nghiem voi 10.000 phan tu...\n";
    chayThuNghiem(10000, tL1, tB1);
    cout << "Dang chay thu nghiem voi 100.000 phan tu...\n";
    chayThuNghiem(100000, tL2, tB2);
    cout << "Dang chay thu nghiem voi 1.000.000 phan tu...\n";
    chayThuNghiem(1000000, tL3, tB3);

    cout << "\n=============================================\n";
    cout << setw(15) << left << "So luong (N)" 
         << setw(20) << left << "Linear Search (ms)" 
         << setw(20) << left << "Binary Search (ms)" << endl;
    cout << "---------------------------------------------\n";
    cout << setw(15) << left << "10.000" 
         << setw(20) << left << fixed << setprecision(5) << tL1 
         << setw(20) << left << fixed << setprecision(5) << tB1 << endl;
    cout << setw(15) << left << "100.000" 
         << setw(20) << left << fixed << setprecision(5) << tL2 
         << setw(20) << left << fixed << setprecision(5) << tB2 << endl;
    cout << setw(15) << left << "1.000.000" 
         << setw(20) << left << fixed << setprecision(5) << tL3 
         << setw(20) << left << fixed << setprecision(5) << tB3 << endl;
    cout << "=============================================\n";

    return 0;
}
Bài 4: 🔥 Dự Án Mini — Từ Điển Anh–Việt BST ⭐⭐⭐
#include <iostream>
#include <string>
#include <chrono>
using namespace std;
using namespace std::chrono;

struct ThongTin {
    string hoTen;
    string sdt;
};

void sapXepTheoSdt(ThongTin danhBa[], int n) {
    for (int i = 0; i < n - 1; i++) {
        int minIdx = i;
        for (int j = i + 1; j < n; j++) {
            if (danhBa[j].sdt < danhBa[minIdx].sdt) {
                minIdx = j;
            }
        }
        if (minIdx != i) {
            ThongTin temp = danhBa[i];
            danhBa[i] = danhBa[minIdx];
            danhBa[minIdx] = temp;
        }
    }
}

void timTheoTen(ThongTin danhBa[], int n, string tenCanTim) {
    int soBuoc = 0;
    int demKetQua = 0;
    auto start = high_resolution_clock::now();

    cout << "\n--- KET QUA TIM KIEM THEO TEN ---\n";
    for (int i = 0; i < n; i++) {
        soBuoc++;
        if (danhBa[i].hoTen.find(tenCanTim) != string::npos) {
            demKetQua++;
            cout << demKetQua << ". " << danhBa[i].hoTen << " - " << danhBa[i].sdt << endl;
        }
    }

    if (demKetQua == 0) {
        cout << "Khong tim thay ket qua trung khop. Goi y 3 thong tin dau trong danh ba:\n";
        int goiY = (n < 3) ? n : 3;
        for (int i = 0; i < goiY; i++) {
            cout << "   + " << danhBa[i].hoTen << " - " << danhBa[i].sdt << endl;
        }
    }

    auto end = high_resolution_clock::now();
    double thoiGian = duration<double, milli>(end - start).count();
    cout << "(Da so sanh " << soBuoc << "/" << n << " phan tu - " << fixed << setprecision(4) << thoiGian << " ms)\n";
}

void timTheoSdt(ThongTin danhBa[], int n, string sdtCanTim) {
    sapXepTheoSdt(danhBa, n);

    int soBuoc = 0;
    int left = 0, right = n - 1;
    int viTri = -1;
    auto start = high_resolution_clock::now();

    while (left <= right) {
        soBuoc++;
        int mid = left + (right - left) / 2;
        if (danhBa[mid].sdt == sdtCanTim) {
            viTri = mid;
            break;
        }
        if (danhBa[mid].sdt < sdtCanTim) left = mid + 1;
        else right = mid - 1;
    }

    cout << "\n--- KET QUA TIM KIEM THEO SDT (BINARY SEARCH) ---\n";
    if (viTri != -1) {
        cout << "Tim thay: " << danhBa[viTri].hoTen << " - " << danhBa[viTri].sdt << endl;
    } else {
        cout << "Khong tim thay thong tin trung khop cho SDT: " << sdtCanTim << endl;
    }

    auto end = high_resolution_clock::now();
    double thoiGian = duration<double, milli>(end - start).count();
    cout << "(Da so sanh " << soBuoc << " lan trong thuat toan - " << fixed << setprecision(4) << thoiGian << " ms)\n";
}

int main() {
    int n = 5;
    ThongTin* danhBa = new ThongTin[n];
    
    danhBa[0] = {"Nguyen Van Minh", "0901234567"};
    danhBa[1] = {"Tran Thi Minh Anh", "0912345678"};
    danhBa[2] = {"Le Minh Tuan", "0923456789"};
    danhBa[3] = {"Pham Hoang Long", "0934567890"};
    danhBa[4] = {"Vu Thu Thao", "0945678901"};

    int luaChon;
    do {
        cout << "\n=== SMART SEARCH ENGINE MENU ===\n";
        cout << "1. Tim kiem theo ten (Linear Search - Tim kiem mo)\n";
        cout << "2. Tim kiem theo so dien thoai (Binary Search)\n";
        cout << "0. Thoat\n";
        cout << "Nhap lua chon cua ban: ";
        cin >> luaChon;
        cin.ignore();

        if (luaChon == 1) {
            string ten;
            cout << "Nhap ten can tim: ";
            getline(cin, ten);
            timTheoTen(danhBa, n, ten);
        } else if (luaChon == 2) {
            string sdt;
            cout << "Nhap SDT can tim: ";
            cin >> sdt;
            timTheoSdt(danhBa, n, sdt);
        }
    } while (luaChon != 0);

    delete[] danhBa;
    return 0;
}
