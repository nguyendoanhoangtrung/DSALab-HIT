#include <iostream>
#include <string>
using namespace std;

int linearSearchInt(int arr[], int n, int x, int &soBuoc) {
    soBuoc = 0;
    for (int i = 0; i < n; i++) {
        soBuoc++;
        if (arr[i] == x) {
            return i;
        }
    }
    return -1;
}

int linearSearchString(string arr[], int n, string x, int &soBuoc) {
    soBuoc = 0;
    for (int i = 0; i < n; i++) {
        soBuoc++;
        if (arr[i] == x) {
            return i;
        }
    }
    return -1;
}

int main() {
    int n;
    cout << "Nhap so phan tu mảng so nguyen: ";
    cin >> n;
    int* arrInt = new int[n];
    for (int i = 0; i < n; i++) {
        cout << "Nhap phan tu " << i << ": ";
        cin >> arrInt[i];
    }
    int x;
    cout << "Nhap gia tri so nguyen can tim: ";
    cin >> x;
    int buocInt = 0;
    int vtInt = linearSearchInt(arrInt, n, x, buocInt);
    if (vtInt != -1) {
        cout << "Tim thay tai vi tri: " << vtInt << " (So buoc so sanh: " << buocInt << ")\n";
    } else {
        cout << "Khong tim thay! (So buoc so sanh: " << buocInt << ")\n";
    }

    int m;
    cout << "\nNhap so phan tu mang chuoi: ";
    cin >> m;
    string* arrStr = new string[m];
    for (int i = 0; i < m; i++) {
        cout << "Nhap chuoi " << i << ": ";
        cin >> arrStr[i];
    }
    string s;
    cout << "Nhap chuoi can tim: ";
    cin >> s;
    int buocStr = 0;
    int vtStr = linearSearchString(arrStr, m, s, buocStr);
    if (vtStr != -1) {
        cout << "Tim thay tai vi tri: " << vtStr << " (So buoc so sanh: " << buocStr << ")\n";
    } else {
        cout << "Khong tim thay! (So buoc so sanh: " << buocStr << ")\n";
    }

    delete[] arrInt;
    delete[] arrStr;
    return 0;
}
Bài 2: Kiểm tra BST hợp lệ ⭐⭐
#include <iostream>
using namespace std;

int binarySearchIterative(int arr[], int n, int x) {
    int left = 0, right = n - 1;
    while (left <= right) {
        int mid = left + (right - left) / 2;
        if (arr[mid] == x) return mid;
        if (arr[mid] < x) left = mid + 1;
        else right = mid - 1;
    }
    return -1;
}

int binarySearchRecursive(int arr[], int left, int right, int x) {
    if (left > right) return -1;
    int mid = left + (right - left) / 2;
    if (arr[mid] == x) return mid;
    if (arr[mid] < x) return binarySearchRecursive(arr, mid + 1, right, x);
    return binarySearchRecursive(arr, left, mid - 1, x);
}

int timViTriDauTien(int arr[], int n, int x) {
    int left = 0, right = n - 1, res = -1;
    while (left <= right) {
        int mid = left + (right - left) / 2;
        if (arr[mid] == x) {
            res = mid;
            right = mid - 1;
        } else if (arr[mid] < x) left = mid + 1;
        else right = mid - 1;
    }
    return res;
}

int timViTriCuoiCung(int arr[], int n, int x) {
    int left = 0, right = n - 1, res = -1;
    while (left <= right) {
        int mid = left + (right - left) / 2;
        if (arr[mid] == x) {
            res = mid;
            left = mid + 1;
        } else if (arr[mid] < x) left = mid + 1;
        else right = mid - 1;
    }
    return res;
}

int main() {
    int n;
    cout << "Nhap so phan tu mang da sap xep tang dan: ";
    cin >> n;
    int* arr = new int[n];
    for (int i = 0; i < n; i++) {
        cout << "Nhap phan tu " << i << ": ";
        cin >> arr[i];
    }
    int x;
    cout << "Nhap gia tri can tim: ";
    cin >> x;

    cout << "\nKiem tra Binary Search co ban:\n";
    cout << "- Vi tri (Vong lap): " << binarySearchIterative(arr, n, x) << endl;
    cout << "- Vi tri (De quy): " << binarySearchRecursive(arr, 0, n - 1, x) << endl;

    cout << "\nKiem tra tim vi tri bien trung:\n";
    cout << "- Vi tri dau tien xuat hien: " << timViTriDauTien(arr, n, x) << endl;
    cout << "- Vi tri cuoi cung xuat hien: " << timViTriCuoiCung(arr, n, x) << endl;

    delete[] arr;
    return 0;
}
