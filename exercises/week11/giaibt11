#include <iostream>
#include <string>

using namespace std;

// 1. Định nghĩa cấu trúc một nút trên cây
struct Node {
    int data;
    Node* left;
    Node* right;
};

// Hàm tạo một nút mới
Node* createNode(int value) {
    Node* newNode = new Node();
    newNode->data = value;
    newNode->left = nullptr;
    newNode->right = nullptr;
    return newNode;
}

// 2. Hàm thêm phần tử vào cây (Insert)
Node* insert(Node* root, int value) {
    if (root == nullptr) {
        return createNode(value);
    }
    if (value < root->data) {
        root->left = insert(root->left, value);
    }
    else if (value > root->data) {
        root->right = insert(root->right, value);
    }
    else {
        cout << "Gia tri " << value << " da ton tai tren cay!" << endl;
    }
    return root;
}

// 3. Hàm tìm kiếm một phần tử (Search)
Node* search(Node* root, int value) {
    if (root == nullptr || root->data == value) {
        return root;
    }
    if (value < root->data) {
        return search(root->left, value);
    }
    return search(root->right, value);
}

// --- CÁC HÀM TÌM NÚT THAY THẾ CHO PHẦN XÓA ---
// Trường hợp 1: Tìm nút TRÁI NHẤT của cây con PHẢI
Node* findMin(Node* root) {
    Node* current = root;
    while (current && current->left != nullptr) {
        current = current->left;
    }
    return current;
}

// Trường hợp 2: Tìm nút PHẢI NHẤT của cây con TRÁI
Node* findMax(Node* root) {
    Node* current = root;
    while (current && current->right != nullptr) {
        current = current->right;
    }
    return current;
}

// 4. Hàm xóa phần tử (Delete) với lựa chọn chiến lược thay thế (Trái/Phải)
// mode = 1: Thay bằng nút trái nhất của cây con phải
// mode = 2: Thay bằng nút phải nhất của cây con trái
Node* deleteNode(Node* root, int value, int mode) {
    if (root == nullptr) return root;

    // Bước 1: Tìm nút cần xóa
    if (value < root->data) {
        root->left = deleteNode(root->left, value, mode);
    }
    else if (value > root->data) {
        root->right = deleteNode(root->right, value, mode);
    }
    // Đã tìm thấy nút cần xóa!
    else {
        // Trường hợp nút có 0 con hoặc chỉ có 1 con
        if (root->left == nullptr) {
            Node* temp = root->right;
            delete root;
            return temp;
        }
        else if (root->right == nullptr) {
            Node* temp = root->left;
            delete root;
            return temp;
        }

        // Trường hợp nút có đầy đủ 2 con
        if (mode == 1) {
            // Cách 1: Phải nhất của con trái HOẶC trái nhất của con phải. 
            // Thầy yêu cầu phân biệt Trái/Phải thì đây là nhánh PHẢI (Trái nhất của nhánh phải)
            Node* temp = findMin(root->right);
            root->data = temp->data;
            root->right = deleteNode(root->right, temp->data, mode);
        }
        else {
            // Cách 2: Nhánh TRÁI (Phải nhất của nhánh trái)
            Node* temp = findMax(root->left);
            root->data = temp->data;
            root->left = deleteNode(root->left, temp->data, mode);
        }
    }
    return root;
}

// 5. Hàm vẽ cây trực quan dạng text (Print Tree giống hình mẫu)
void printTree(Node* root, string indent = "", bool isRight = true) {
    if (root != nullptr) {
        printTree(root->right, indent + (isRight ? "    " : "|   "), true);

        cout << indent;
        if (indent == "") {
            cout << "--- ";
        }
        else {
            cout << (isRight ? "/-- " : "\\-- ");
        }
        cout << root->data << endl;

        printTree(root->left, indent + (isRight ? "|   " : "    "), false);
    }
}

// 6. Ứng dụng: Duyệt cây theo thứ tự giữa (InOrder) để xuất ra mảng tăng dần
void InOrder(Node* root) {
    if (root != nullptr) {
        InOrder(root->left);
        cout << root->data << " ";
        InOrder(root->right);
    }
}

// --- HÀM MENU CHÍNH ---
int main() {
    Node* root = nullptr;
    int choice, value, mode;

    // Khởi tạo sẵn một vài phần tử giống hình mẫu của bạn để test cho nhanh
    int default_data[] = { 5, 7, 4, 8, 6, 2, 1, 3 };
    for (int x : default_data) {
        root = insert(root, x);
    }

    while (true) {
        cout << "\n================ MENU BST ================\n";
        cout << "1. Them phan tu vao cay\n";
        cout << "2. Tim kiem phan tu\n";
        cout << "3. Xoa phan tu khoi cay\n";
        cout << "4. Xem cay\n";
        cout << "0. Thoat\n";
        cout << "==========================================\n";
        cout << "Nhap lua chon cua ban: ";
        cin >> choice;

        switch (choice) {
        case 1:
            cout << "Nhap gia tri can them: ";
            cin >> value;
            root = insert(root, value);
            cout << "\n[Da cap nhat] Cau truc cay hien tai:\n";
            printTree(root);
            break;

        case 2:
            cout << "Nhap gia tri can tim kiếm: ";
            cin >> value;
            if (search(root, value) != nullptr) {
                cout << "==> KET QUA: Tim thay nut " << value << " tren cay!\n";
            }
            else {
                cout << "==> KET QUA: Khong tim thay nut " << value << ".\n";
            }
            break;

        case 3:
            cout << "Nhap gia tri can xoa: ";
            cin >> value;
            if (search(root, value) == nullptr) {
                cout << "Gia tri " << value << " khong ton tai tren cay!\n";
                break;
            }

            cout << "Chon truong hop thay the nut khi co 2 con:\n";
            cout << "  1 - Nho nhat cua cay con PHAI\n";
            cout << "  2 - Lon nhat cua cay con TRAI\n";
            cout << "Nhap lua chon: ";
            cin >> mode;

            if (mode != 1 && mode != 2) {
                cout << "Lua chon khong hop le! Mac dinh chon cach 1.\n";
                mode = 1;
            }

            root = deleteNode(root, value, mode);
            cout << "\nCau truc cay sau khi xoa " << value << ":\n";
            printTree(root);
            break;

        case 4:
            cout << "\n--- CAU TRUC CAY HIEN TAI ---\n";
            if (root == nullptr) {
                cout << "(Cay dang trong)\n";
            }
            else {
                printTree(root);
            }
            break;

        case 5:
            cout << "Danh sach phan tu: ";
            if (root == nullptr) cout << "(Cay trong)";
            else InOrder(root);
            cout << endl;
            break;

        case 0:
            cout << "Tam biet!\n";
            return 0;

        default:
            cout << "Lua chon khong hop le, vui long nhap lai!\n";
        }
    }
    return 0;
}
