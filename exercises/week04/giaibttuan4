#include <iostream>

using namespace std;

void inMang(int arr[], int n) {
    for (int i = 0; i < n; i++) {
        cout << arr[i] << " ";
    }
    cout << endl;
}

void bubbleSort(int arr[], int n) {
    int* tempArr = new int[n];
    for (int i = 0; i < n; i++) tempArr[i] = arr[i];

    cout << "\n--- BUBBLE SORT STAGES ---\n";
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (tempArr[j] > tempArr[j + 1]) {
                int temp = tempArr[j];
                tempArr[j] = tempArr[j + 1];
                tempArr[j + 1] = temp;
            }
        }
        cout << "Buoc " << i + 1 << ": ";
        inMang(tempArr, n);
    }
    delete[] tempArr;
}

void selectionSort(int arr[], int n) {
    int* tempArr = new int[n];
    for (int i = 0; i < n; i++) tempArr[i] = arr[i];

    cout << "\n--- SELECTION SORT STAGES ---\n";
    for (int i = 0; i < n - 1; i++) {
        int minIdx = i;
        for (int j = i + 1; j < n; j++) {
            if (tempArr[j] < tempArr[minIdx]) {
                minIdx = j;
            }
        }
        int temp = tempArr[minIdx];
        tempArr[minIdx] = tempArr[i];
        tempArr[i] = temp;

        cout << "Buoc " << i + 1 << ": ";
        inMang(tempArr, n);
    }
    delete[] tempArr;
}

void insertionSort(int arr[], int n) {
    int* tempArr = new int[n];
    for (int i = 0; i < n; i++) tempArr[i] = arr[i];

    cout << "\n--- INSERTION SORT STAGES ---\n";
    for (int i = 1; i < n; i++) {
        int key = tempArr[i];
        int j = i - 1;
        while (j >= 0 && tempArr[j] > key) {
            tempArr[j + 1] = tempArr[j];
            j--;
        }
        tempArr[j + 1] = key;

        cout << "Buoc " << i << ": ";
        inMang(tempArr, n);
    }
    delete[] tempArr;
}

int main() {
    int n;
    cout << "Nhap so phan tu n: ";
    cin >> n;
    int* arr = new int[n];
    for (int i = 0; i < n; i++) {
        cout << "Nhap phan tu " << i << ": ";
        cin >> arr[i];
    }

    bubbleSort(arr, n);
    selectionSort(arr, n);
    insertionSort(arr, n);

    delete[] arr;
    return 0;
}
