#include <iostream>
#include <iomanip>
#include <cstdlib>

using namespace std;

void taoMangNgauNhien(int arr[], int n) {
    for (int i = 0; i < n; i++) {
        arr[i] = rand() % 500;
    }
}

void saoChepMang(int nguon[], int dich[], int n) {
    for (int i = 0; i < n; i++) {
        dich[i] = nguon[i];
    }
}

void demBubbleSort(int arr[], int n, long long &soSanh, long long &hoanVi) {
    soSanh = 0;
    hoanVi = 0;
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            soSanh++;
            if (arr[j] > arr[j + 1]) {
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
                hoanVi++;
            }
        }
    }
}

void demSelectionSort(int arr[], int n, long long &soSanh, long long &hoanVi) {
    soSanh = 0;
    hoanVi = 0;
    for (int i = 0; i < n - 1; i++) {
        int minIdx = i;
        for (int j = i + 1; j < n; j++) {
            soSanh++;
            if (arr[j] < arr[minIdx]) {
                minIdx = j;
            }
        }
        if (minIdx != i) {
            int temp = arr[minIdx];
            arr[minIdx] = arr[i];
            arr[i] = temp;
            hoanVi++;
        }
    }
}

void demInsertionSort(int arr[], int n, long long &soSanh, long long &hoanVi) {
    soSanh = 0;
    hoanVi = 0;
    for (int i = 1; i < n; i++) {
        int key = arr[i];
        int j = i - 1;
        while (j >= 0) {
            soSanh++;
            if (arr[j] > key) {
                arr[j + 1] = arr[j];
                hoanVi++;
                j--;
            } else {
                break;
            }
        }
        if (j >= 0 && arr[j] <= key) {
        }
        arr[j + 1] = key;
    }
}

int main() {
    int n = 100;
    int* mangGoc = new int[n];
    int* mangPhu = new int[n];

    taoMangNgauNhien(mangGoc, n);

    long long ssBubble = 0, hvBubble = 0;
    long long ssSelect = 0, hvSelect = 0;
    long long ssInsert = 0, hvInsert = 0;

    saoChepMang(mangGoc, mangPhu, n);
    demBubbleSort(mangPhu, n, ssBubble, hvBubble);

    saoChepMang(mangGoc, mangPhu, n);
    demSelectionSort(mangPhu, n, ssSelect, hvSelect);

    saoChepMang(mangGoc, mangPhu, n);
    demInsertionSort(mangPhu, n, ssInsert, hvInsert);

    cout << "\n======================================================\n";
    cout << setw(20) << left << "Thuat Toan" 
